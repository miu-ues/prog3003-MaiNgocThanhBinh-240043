package Bai3;

// Class WorkerThread kế thừa từ Thread
class WorkerThread extends Thread {
    @Override
    public void run() {
        for (int i = 0; i < 5; i++) {
            System.out.println("Thread đang chạy... - Lần " + (i + 1));
            try {
                Thread.sleep(500);
            } catch (InterruptedException e) {
                e.printStackTrace();
            }
        }
    }
}

// Class WorkerRunnable implements Runnable
class WorkerRunnable implements Runnable {
    @Override
    public void run() {
        for (int i = 0; i < 5; i++) {
            System.out.println("Runnable đang chạy... - Lần " + (i + 1));
            try {
                Thread.sleep(500);
            } catch (InterruptedException e) {
                e.printStackTrace();
            }
        }
    }
}

public class exthree {
    public static void main(String[] args) {
        System.out.println("=== Demo Thread và Runnable ===\n");
        
        // Khởi chạy WorkerThread
        WorkerThread thread1 = new WorkerThread();
        thread1.start();
        
        // Khởi chạy WorkerRunnable
        WorkerRunnable runnable = new WorkerRunnable();
        Thread thread2 = new Thread(runnable);
        thread2.start();
        
        // Chờ cả hai thread hoàn thành
        try {
            thread1.join();
            thread2.join();
        } catch (InterruptedException e) {
            e.printStackTrace();
        }
        
        System.out.println("\nCả hai thread đã hoàn thành!");
    }
}
